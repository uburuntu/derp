# Required app secrets
TELEGRAM_BOT_TOKEN=
DATABASE_URL=postgresql://derp:derp@localhost:5433/derp
GOOGLE_API_KEY=

# Optional app settings
ENVIRONMENT=dev
BOT_USERNAME=DerpRobot
HEALTH_PORT=8080

# Docker Compose PostgreSQL settings
POSTGRES_USER=derp
POSTGRES_PASSWORD=derp
POSTGRES_DB=derp
POSTGRES_PORT=5433
POSTGRES_TEST_DB=derp_test
POSTGRES_TEST_PORT=5434

# Optional — comma-separated additional Google API keys for round-robin
# GOOGLE_API_KEYS=key1,key2,key3

# Optional — paid Google API key (used for image/video generation)
# GOOGLE_API_PAID_KEY=

# Optional — Brave Search API key (falls back to DuckDuckGo if not set)
# BRAVE_SEARCH_API_KEY=

# Optional — comma-separated bot admin Telegram user IDs
# BOT_ADMIN_IDS=123456,789012

# Optional — chat ID to receive payment/refund/startup notifications
# BOT_ADMIN_EVENTS_CHAT_ID=

# Optional — Logfire observability (https://logfire.pydantic.dev)
# LOGFIRE_TOKEN=

# Optional — OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=derp

# Optional — reminder scheduler interval (default 60000ms = 1 minute)
# REMINDER_CHECK_INTERVAL_MS=60000
